{
  "name": "ddl-cp-web",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=20.9.0"
  },
  "scripts": {
    "dev": "prisma db push --skip-generate && tsx lib/seed.ts && next dev",
    "build": "prisma generate && prisma db push --accept-data-loss --skip-generate && tsx lib/seed.ts && next build",
    "start": "next start",
    "lint": "next lint",
    "db:push": "prisma db push",
    "db:seed": "tsx lib/seed.ts",
    "postinstall": "prisma generate"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "@types/nodemailer": "^8.0.0",
    "bcryptjs": "^3.0.3",
    "exceljs": "^4.4.0",
    "lucide-react": "^0.469.0",
    "next": "^16.2.4",
    "nodemailer": "^8.0.6",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "recharts": "^2.15.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.0.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^22",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "postcss": "^8",
    "prisma": "^5.22.0",
    "tailwindcss": "^4.0.0",
    "tsx": "^4.19.2",
    "typescript": "^5"
  }
}
