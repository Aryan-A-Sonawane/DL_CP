# ─────────────────────────────────────────────────────────────────────
# DATABASE  (REQUIRED — Postgres connection string)
# ─────────────────────────────────────────────────────────────────────
# Local dev:    docker run --name frm-pg -e POSTGRES_PASSWORD=postgres -p 5432:5432 -d postgres:16
#               DATABASE_URL=postgresql://postgres:postgres@localhost:5432/frm
# Neon (free):  https://neon.tech → create project → copy "Pooled connection"
# Vercel PG:    Vercel dashboard → Storage → Create → Postgres
#
# The pooled URL must include `?sslmode=require` for hosted providers.
DATABASE_URL=postgresql://user:password@host:5432/dbname?sslmode=require

# ─────────────────────────────────────────────────────────────────────
# AUTH  (REQUIRED in production — random 32+ char string)
# ─────────────────────────────────────────────────────────────────────
# Generate one:  node -e "console.log(require('crypto').randomBytes(32).toString('base64url'))"
SESSION_SECRET=change-me-to-a-32-plus-char-random-string

# ─────────────────────────────────────────────────────────────────────
# APP URL  (used in invitation email links)
# ─────────────────────────────────────────────────────────────────────
APP_URL=http://localhost:3000
# Production example: APP_URL=https://your-app.vercel.app

# ─────────────────────────────────────────────────────────────────────
# SUPER-ADMIN SEED  (only used the very first time `npm run db:seed` runs)
# ─────────────────────────────────────────────────────────────────────
# If SUPER_ADMIN_PASSWORD is left unset, the seed script will generate a
# strong random password and print it once to the deploy logs — copy it
# from there and store it somewhere safe.
SUPER_ADMIN_EMAIL=owner@platform.local
SUPER_ADMIN_NAME=Platform Owner
# SUPER_ADMIN_PASSWORD=

# ─────────────────────────────────────────────────────────────────────
# SMTP / EMAIL  (optional — invitation emails are skipped if missing)
# ─────────────────────────────────────────────────────────────────────
# Gmail setup:
#   1. Turn on 2-Step Verification on the Google account
#      https://myaccount.google.com/security
#   2. Create a 16-character App Password
#      https://myaccount.google.com/apppasswords
#      (App: "Mail", Device: "Other -> Failure-to-Role")
#   3. Paste the 16 chars (no spaces) into SMTP_PASS
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM=
